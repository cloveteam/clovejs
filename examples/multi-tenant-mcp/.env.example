# Copy to .env to override the defaults below.

# The public origin this server is reached at. Everything else derives from it:
# the MCP endpoint (and token audience) is PUBLIC_URL + /mcp.
# PUBLIC_URL=http://localhost:3000

# Signs the MCP session cookie / id. Set in production.
# CLOVE_SECRET=change-me

# --- Point at a real IdP instead of the built-in dev authorization server ---
# Set all three to verify tokens issued by Auth0/Okta/Keycloak/Entra. When
# OAUTH_JWKS_URL is set the /api/dev/* token endpoints turn themselves off.
# OAUTH_ISSUER=https://your-tenant.us.auth0.com/
# OAUTH_AUDIENCE=http://localhost:3000/mcp
# OAUTH_JWKS_URL=https://your-tenant.us.auth0.com/.well-known/jwks.json
