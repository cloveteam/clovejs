{
  "name": "clovejs",
  "version": "0.1.0",
  "description": "A simple, convention-driven NodeJS HTTP framework with TypeScript and DI in the box.",
  "type": "module",
  "license": "MIT",
  "homepage": "https://cloveteam.github.io/clovejs/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cloveteam/clovejs.git"
  },
  "bugs": {
    "url": "https://github.com/cloveteam/clovejs/issues"
  },
  "engines": {
    "node": ">=20"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "clove": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "templates",
    "README.md"
  ],
  "workspaces": [
    "examples/*"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "http",
    "framework",
    "typescript",
    "dependency-injection",
    "file-based-routing",
    "websocket"
  ],
  "dependencies": {
    "chokidar": "^4.0.3",
    "jiti": "^2.4.2",
    "listhen": "^1.9.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/express": "^5.0.6",
    "@types/node": "^22.10.0",
    "@types/ws": "^8.5.13",
    "eslint": "^10.7.0",
    "expect-type": "^1.1.0",
    "express": "^5.2.1",
    "globals": "^17.7.0",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.64.0",
    "vitepress": "^1.6.4",
    "vitest": "^2.1.8"
  }
}
